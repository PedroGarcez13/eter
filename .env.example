# Copie este arquivo para .env e preencha com as chaves do seu projeto Supabase.
# Encontre estes valores em: Supabase > Project Settings > API.
# A "anon key" é pública (pode ir pro frontend); ela é segura porque o acesso
# é controlado pelas políticas de Row Level Security definidas em supabase/schema.sql.

VITE_SUPABASE_URL=https://SEU-PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=sua-anon-key-aqui
